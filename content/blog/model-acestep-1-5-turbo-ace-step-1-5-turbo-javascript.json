      {
        "type": "code_block",
        "lang": "javascript",
        "value": "const retryRequest = async (fn, retries = 3) => {\n  for (let i = 0; i < retries; i++) {\n    try {\n      return await fn();\n    } catch (error) {\n      if (i === retries - 1) throw error;\n      await new Promise(resolve => setTimeout(resolve, 1000 * Math.pow(2, i)));\n    }\n  }\n};",
