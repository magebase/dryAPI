                "type": "lic",
                "children": [
                  {
                    "type": "text",
                    "text": "Low Confidence Scores",
                    "bold": true
                  },
                  {
                    "type": "text",
                    "text": ": Pre-process images to improve resolution or contrast."
                  }
                ]
              }
            ]
