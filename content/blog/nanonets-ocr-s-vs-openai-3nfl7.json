                "children": [
                  {
                    "type": "text",
                    "text": "Error 429 (Rate Limit)",
                    "bold": true
                  },
                  {
                    "type": "text",
                    "text": ": Implement exponential backoff in your client."
                  }
                ]
              }
            ]
          },
