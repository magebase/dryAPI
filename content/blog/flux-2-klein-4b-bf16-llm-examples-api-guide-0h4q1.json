      {
        "type": "code_block",
        "lang": "python",
        "value": "import time\n\nmax_retries = 3\nfor attempt in range(max_retries):\n    response = requests.post(\"https://api.example.com/v1/generate\", headers=headers, json=data)\n    if response.status_code == 200:\n        result = response.json()\n        # Process result\n        break\n    elif response.status_code == 429:  # Rate limit\n        time.sleep(2 ** attempt)  # Exponential backoff\n    else:\n        raise Exception(f\"API error: {response.status_code} - {response.text}\")",
        "children": [
          {
            "type": "code_line",
            "children": [
              {
                "text": "import time"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": ""
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "max_retries = 3"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "for attempt in range(max_retries):"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "    response = requests.post(\"https://api.example.com/v1/generate\", headers=headers, json=data)"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "    if response.status_code == 200:"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "        result = response.json()"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "        # Process result"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "        break"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "    elif response.status_code == 429:  # Rate limit"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "        time.sleep(2 ** attempt)  # Exponential backoff"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "    else:"
              }
            ]
