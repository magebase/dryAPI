                  {
                    "type": "text",
                    "text": "Prepare the Request Payload",
                    "bold": true
                  },
                  {
                    "type": "text",
                    "text": ": Encode your image as base64 or provide a URL. Include headers for authentication and content type."
                  }
                ]
              }
            ]
          },
          {
            "type": "li",
            "children": [
              {
                "type": "lic",
                "children": [
                  {
                    "type": "text",
                    "text": "Handle the Response",
                    "bold": true
                  },
                  {
                    "type": "text",
                    "text": ": Parse the JSON output, which includes extracted text, bounding boxes, and confidence scores."
                  }
                ]
              }
