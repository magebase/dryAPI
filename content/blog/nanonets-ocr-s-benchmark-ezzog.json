              }
            ]
          },
          {
            "type": "text",
            "text": " for detailed comparisons."
          }
        ]
      },
      {
        "type": "h2",
        "children": [
          {
            "type": "text",
            "text": "Limitations and Troubleshooting"
          }
        ]
      },
      {
        "type": "p",
        "children": [
          {
            "type": "text",
            "text": "Despite its strengths, Nanonets OCR S has constraints: it struggles with extremely low-contrast images (e.g., faded faxes) and complex multi-column layouts without explicit configuration. The model also has a maximum image size limit of 4096 pixels per side, and requests exceeding this will return a 400 error."
          }
        ]
      },
      {
        "type": "blockquote",
        "children": [
          {
            "type": "text",
            "text": "Warning:",
            "bold": true
          },
          {
            "type": "text",
            "text": " Avoid using the synchronous endpoint for images larger than 5MB; switch to the asynchronous API to prevent timeouts. Monitor the "
          },
          {
            "type": "text",
            "text": "X-RateLimit-Remaining",
            "code": true
          },
          {
            "type": "text",
            "text": " header to avoid 429 errors."
          }
        ]
      },
      {
        "type": "p",
        "children": [
          {
            "type": "text",
            "text": "Common issues include authentication failures (error 401) due to expired keys and malformed JSON payloads. Implement exponential backoff for retries, and log request IDs from the "
          },
          {
            "type": "text",
            "text": "X-Request-Id",
            "code": true
          },
          {
            "type": "text",
            "text": " header for debugging with Nanonets support."
          }
        ]
      },
      {
        "type": "h2",
        "children": [
          {
            "type": "text",
            "text": "Deployment Notes for High Availability"
          }
        ]
      },
      {
        "type": "p",
        "children": [
          {
            "type": "text",
            "text": "For production deployment, run Nanonets OCR S behind a load balancer with auto-scaling groups to handle traffic spikes. Use containerization with Docker for consistency, and set health checks on the "
          },
          {
            "type": "text",
            "text": "/health",
            "code": true
          },
          {
            "type": "text",
            "text": " endpoint. Below is a sample Dockerfile and deployment script."
          }
        ]
      },
      {
        "type": "code_block",
        "lang": "bash",
        "value": "# Dockerfile for Nanonets OCR S client\nFROM python:3.9-slim\nWORKDIR /app\nCOPY requirements.txt .\nRUN pip install -r requirements.txt\nCOPY . .\nCMD [\"python\", \"app.py\"]",
        "children": [
          {
            "type": "code_line",
            "children": [
              {
                "text": "# Dockerfile for Nanonets OCR S client"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "FROM python:3.9-slim"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "WORKDIR /app"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "COPY requirements.txt ."
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "RUN pip install -r requirements.txt"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "COPY . ."
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "CMD [\"python\", \"app.py\"]"
              }
            ]
          }
        ]
      },
      {
        "type": "code_block",
        "lang": "yaml",
        "value": "# docker-compose.yml for local testing\nversion: '3'\nservices:\n  ocr-service:\n    build: .\n    environment:\n      - NANONETS_API_KEY=${API_KEY}\n    ports:\n      - \"8080:8080\"\n    deploy:\n      replicas: 3",
        "children": [
          {
            "type": "code_line",
            "children": [
              {
                "text": "# docker-compose.yml for local testing"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "version: '3'"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "services:"
              }
            ]
          },
          {
            "type": "code_line",
