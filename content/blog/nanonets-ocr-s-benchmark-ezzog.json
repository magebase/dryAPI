                "type": "lic",
                "children": [
                  {
                    "type": "text",
                    "text": "Implement Error Handling",
                    "bold": true
                  },
                  {
                    "type": "text",
                    "text": ": Check for HTTP status codes and retry on transient errors like 429 (rate limits) or 503 (service unavailable)."
                  }
                ]
              }
            ]
          }
        ]
