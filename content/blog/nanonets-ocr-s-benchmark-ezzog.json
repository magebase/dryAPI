                    "bold": true
                  },
                  {
                    "type": "text",
                    "text": ": Sign up at Nanonets, navigate to the API keys section, and generate a key for the "
                  },
                  {
                    "type": "text",
                    "text": "Nanonets_Ocr_S_F16",
                    "code": true
                  },
                  {
                    "type": "text",
                    "text": " model."
                  }
