            "text": ", and "
          },
          {
            "type": "text",
            "text": "boxes",
            "code": true
          },
          {
            "type": "text",
            "text": " for spatial data. Always validate the "
          },
          {
            "type": "text",
            "text": "confidence",
            "code": true
          },
          {
            "type": "text",
            "text": " score—values below 0.85 may require manual review. For batch processing, use asynchronous endpoints to avoid timeouts on large payloads."
          }
        ]
      },
      {
        "type": "code_block",
        "lang": "python",
        "value": "import requests\nimport base64\n\nAPI_KEY = \"your_api_key_here\"\nMODEL_ENDPOINT = \"https://api.nanonets.com/v2/ocr/s/f16\"\n\ndef ocr_image(image_path):\n    with open(image_path, \"rb\") as image_file:\n        encoded_string = base64.b64encode(image_file.read()).decode('utf-8')\n    \n    payload = {\n        \"image\": {\"base64\": encoded_string},\n        \"language\": \"en\",\n        \"output_format\": \"json\"\n    }\n    headers = {\"Authorization\": f\"Basic {API_KEY}\"}\n    \n    response = requests.post(MODEL_ENDPOINT, json=payload, headers=headers)\n    if response.status_code == 200:\n        result = response.json()\n        return result[\"text\"], result[\"confidence\"]\n    else:\n        raise Exception(f\"API error: {response.status_code} - {response.text}\")\n\n# Example usage\ntext, confidence = ocr_image(\"invoice.png\")\nprint(f\"Extracted text: {text} (confidence: {confidence})\")",
        "children": [
          {
            "type": "code_line",
            "children": [
              {
                "text": "import requests"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "import base64"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": ""
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "API_KEY = \"your_api_key_here\""
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "MODEL_ENDPOINT = \"https://api.nanonets.com/v2/ocr/s/f16\""
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": ""
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "def ocr_image(image_path):"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "    with open(image_path, \"rb\") as image_file:"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "        encoded_string = base64.b64encode(image_file.read()).decode('utf-8')"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "    "
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "    payload = {"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "        \"image\": {\"base64\": encoded_string},"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "        \"language\": \"en\","
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "        \"output_format\": \"json\""
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "    }"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "    headers = {\"Authorization\": f\"Basic {API_KEY}\"}"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "    "
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "    response = requests.post(MODEL_ENDPOINT, json=payload, headers=headers)"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "    if response.status_code == 200:"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "        result = response.json()"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "        return result[\"text\"], result[\"confidence\"]"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "    else:"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "        raise Exception(f\"API error: {response.status_code} - {response.text}\")"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": ""
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "# Example usage"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "text, confidence = ocr_image(\"invoice.png\")"
