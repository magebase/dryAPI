          {
            "type": "text",
            "text": ". Requests must include text, a voice ID, and output format. Here's a Python example using the SDK:"
          }
        ]
      },
      {
        "type": "code_block",
        "lang": "python",
        "value": "import qwen3_tts\nfrom qwen3_tts.errors import RateLimitError\n\nclient = qwen3_tts.Client(api_key=\"your_api_key\", region=\"us-east-1\")\ntry:\n    response = client.synthesize(\n        text=\"Welcome to our service. How can I assist you today?\",\n        voice_id=\"custom_voice_abc123\",  # From your voice library\n        output_format=\"mp3\",\n        sample_rate=12000,  # Matches the 12Hz model\n        speed=1.0  # Normal speed\n    )\n    with open(\"output.mp3\", \"wb\") as audio_file:\n        audio_file.write(response.audio_content)\nexcept RateLimitError as e:\n    print(f\"Rate limit exceeded: {e.retry_after} seconds\")",
        "children": [
          {
