          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "        voice_id=\"custom_voice_abc123\",  # From your voice library"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "        output_format=\"mp3\","
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "        sample_rate=12000,  # Matches the 12Hz model"
