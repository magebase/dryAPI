        "type": "code_block",
        "lang": "typescript",
        "value": "import axios from 'axios';\nimport dotenv from 'dotenv';\n\ndotenv.config();\n\nconst API_KEY = process.env.NANONETS_API_KEY;\nconst MODEL_ID = 'Nanonets_Ocr_S_F16';\n\nasync function extractText(imageUrl: string) {\n  try {\n    const response = await axios.post(\n      `https://api.nanonets.com/v2/OCR/Model/${MODEL_ID}/LabelFile/`,\n      { file: imageUrl },\n      {\n        headers: {\n          'Authorization': `Basic ${Buffer.from(`${API_KEY}:`).toString('base64')}`,\n          'Content-Type': 'application/json'\n        }\n      }\n    );\n    return response.data;\n  } catch (error) {\n    console.error('OCR request failed:', error.response?.data || error.message);\n    throw error;\n  }\n}\n\n// Example usage\nextractText('https://example.com/sample-invoice.png')\n  .then(data => console.log('Extracted text:', data))\n  .catch(err => console.error(err));",
