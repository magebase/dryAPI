        "type": "ul",
        "children": [
          {
            "type": "li",
            "children": [
              {
                "type": "lic",
                "children": [
                  {
                    "type": "text",
                    "text": "Use environment variables for API keys and never hardcode them in source code."
                  }
                ]
              }
            ]
          },
          {
            "type": "li",
            "children": [
              {
                "type": "lic",
                "children": [
                  {
                    "type": "text",
                    "text": "Deploy behind a proxy or API gateway to manage rate limits and caching."
                  }
                ]
              }
            ]
          },
