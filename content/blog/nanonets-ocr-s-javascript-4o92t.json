        "type": "ul",
        "children": [
          {
            "type": "li",
            "children": [
              {
                "type": "lic",
                "children": [
                  {
                    "type": "text",
                    "text": "Caching frequent OCR results using Redis or in-memory stores to reduce redundant calls."
                  }
                ]
              }
            ]
          },
          {
            "type": "li",
            "children": [
              {
                "type": "lic",
                "children": [
                  {
                    "type": "text",
                    "text": "Implementing batch processing for bulk image uploads, which can lower per-request overhead."
                  }
                ]
              }
            ]
          },
          {
            "type": "li",
            "children": [
              {
                "type": "lic",
                "children": [
                  {
                    "type": "text",
                    "text": "Using image preprocessing to improve accuracy and reduce retries, thus saving on failed requests."
                  }
                ]
              }
            ]
          }
        ]
