                    "type": "text",
                    "text": "High accuracy on diverse document types, including skewed or low-resolution images."
                  }
                ]
              }
            ]
          },
          {
            "type": "li",
            "children": [
              {
                "type": "lic",
                "children": [
                  {
                    "type": "text",
                    "text": "Low latency, typically under 500ms per request in optimal conditions."
