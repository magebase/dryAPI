      {
        "type": "code_block",
        "lang": "python",
        "value": "from fastapi import FastAPI, HTTPException\nfrom pydantic import BaseModel\nimport torch\nfrom model import Qwen3TTS  # Assume this is the model wrapper from the repo\n\napp = FastAPI()\nmodel = Qwen3TTS.load_from_pretrained(\"models/pretrained.pth\")\n\nclass TTSRequest(BaseModel):\n    text: str\n    voice_id: str = \"default\"  # For custom voice selection\n    speed: float = 1.0\n\n@app.post(\"/synthesize\")\nasync def synthesize_speech(request: TTSRequest):\n    try:\n        audio_data = model.infer(\n            text=request.text,\n            voice_id=request.voice_id,\n            speed=request.speed\n        )\n        # Save to a temporary file or stream directly\n        with open(\"output.wav\", \"wb\") as f:\n            f.write(audio_data)\n        return {\"audio_url\": \"/output.wav\", \"latency_ms\": model.last_inference_time}\n    except Exception as e:\n        raise HTTPException(status_code=500, detail=str(e))\n\nif __name__ == \"__main__\":\n    import uvicorn\n    uvicorn.run(app, host=\"0.0.0.0\", port=8000)",
