            "type": "li",
            "children": [
              {
                "type": "lic",
                "children": [
                  {
                    "type": "text",
                    "text": "401 Unauthorized",
                    "bold": true
                  },
                  {
                    "type": "text",
                    "text": ": Invalid or expired API key. Regenerate keys and update configurations."
                  }
