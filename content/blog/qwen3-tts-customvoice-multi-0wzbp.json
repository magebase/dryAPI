            "type": "li",
            "children": [
              {
                "type": "lic",
                "children": [
                  {
                    "type": "text",
                    "text": "500 Internal Server Error",
                    "bold": true
                  },
                  {
                    "type": "text",
                    "text": ": Temporary service issue; retry after a delay."
                  }
                ]
              }
            ]
          }
