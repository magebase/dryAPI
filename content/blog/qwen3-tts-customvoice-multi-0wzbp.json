        ]
      },
      {
        "type": "p",
        "children": [
          {
            "type": "text",
            "text": "While robust, the API has limitations. It currently supports a maximum text length of 5,000 characters per request, and custom voice cloning requires high-quality audio samples (minimum 16 kHz, mono). Real-time synthesis may degrade under heavy network latency, so implement retry logic with exponential backoff."
          }
        ]
