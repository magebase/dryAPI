      {
        "type": "ul",
        "children": [
          {
            "type": "li",
            "children": [
              {
                "type": "lic",
                "children": [
                  {
                    "type": "text",
                    "text": "Text length",
                    "bold": true
                  },
                  {
                    "type": "text",
                    "text": ": Shorter inputs reduce per-request overhead."
                  }
                ]
              }
            ]
          },
          {
            "type": "li",
            "children": [
              {
                "type": "lic",
                "children": [
                  {
                    "type": "text",
                    "text": "Output format",
                    "bold": true
                  },
                  {
                    "type": "text",
                    "text": ": MP3 compression lowers bandwidth costs compared to WAV."
                  }
                ]
              }
            ]
          },
          {
            "type": "li",
            "children": [
              {
                "type": "lic",
                "children": [
                  {
                    "type": "text",
                    "text": "Batch processing",
                    "bold": true
                  },
                  {
                    "type": "text",
                    "text": ": Use asynchronous endpoints for non-urgent tasks to leverage lower rates."
                  }
                ]
              }
            ]
          },
          {
            "type": "li",
            "children": [
              {
                "type": "lic",
                "children": [
                  {
                    "type": "text",
                    "text": "Caching",
                    "bold": true
                  },
                  {
                    "type": "text",
                    "text": ": Cache frequently used phrases to avoid redundant synthesis."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "p",
        "children": [
          {
            "type": "text",
            "text": "For example, an application generating 10 million characters monthly would cost approximately $150, plus any cloning fees. Monitor usage via the dashboard to set alerts and avoid overages."
          }
        ]
