          {
            "type": "text",
            "text": "https://api.baai.com/embeddings",
            "code": true
          },
          {
            "type": "text",
            "text": ", with authentication via an API key in the "
          },
          {
            "type": "text",
            "text": "Authorization",
            "code": true
          },
          {
            "type": "text",
            "text": " header. Use the "
          },
          {
            "type": "text",
            "text": "bge-m3-fp16",
            "code": true
          },
          {
            "type": "text",
            "text": " model identifier for FP16 precision. Example request:"
          }
        ]
      },
      {
        "type": "code_block",
        "lang": "bash",
        "value": "curl -X POST https://api.baai.com/embeddings \\\n  -H \"Authorization: Bearer YOUR_API_KEY\" \\\n  -H \"Content-Type: application/json\" \\\n  -d '{\"model\": \"bge-m3-fp16\", \"input\": [\"Sample text for embedding\"]}'",
        "children": [
