        ]
      },
      {
        "type": "p",
        "children": [
          {
            "type": "text",
            "text": "Structure requests to handle batches of text inputs. Preprocess texts to remove irrelevant characters and ensure UTF-8 encoding. The API returns embeddings as arrays of floats; parse the "
          },
          {
            "type": "text",
            "text": "embeddings",
            "code": true
          },
          {
            "type": "text",
            "text": " field from the JSON response. Example in Python:"
          }
        ]
      },
      {
        "type": "code_block",
        "lang": "python",
        "value": "import requests\n\ndef fetch_embeddings(texts, api_key):\n    url = \"https://api.baai.com/embeddings\"\n    headers = {\"Authorization\": f\"Bearer {api_key}\", \"Content-Type\": \"application/json\"}\n    payload = {\"model\": \"bge-m3-fp16\", \"input\": texts}\n    response = requests.post(url, headers=headers, json=payload)\n    response.raise_for_status()\n    return response.json()[\"embeddings\"]",
        "children": [
          {
            "type": "code_line",
            "children": [
              {
                "text": "import requests"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": ""
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "def fetch_embeddings(texts, api_key):"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "    url = \"https://api.baai.com/embeddings\""
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "    headers = {\"Authorization\": f\"Bearer {api_key}\", \"Content-Type\": \"application/json\"}"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "    payload = {\"model\": \"bge-m3-fp16\", \"input\": texts}"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "    response = requests.post(url, headers=headers, json=payload)"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "    response.raise_for_status()"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "    return response.json()[\"embeddings\"]"
              }
            ]
          }
        ]
