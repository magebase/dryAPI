            "text": "/v1/process",
            "code": true
          },
          {
            "type": "text",
            "text": " for batch operations and "
          },
          {
            "type": "text",
            "text": "/v1/infer",
            "code": true
          },
          {
            "type": "text",
            "text": " for real-time predictions. Data models are JSON-based, with schemas defined in the OpenAPI specification. Ensure your client handles pagination for large datasets using "
          },
          {
            "type": "text",
            "text": "limit",
            "code": true
          },
          {
            "type": "text",
            "text": " and "
          },
