          {
            "type": "text",
            "text": "3. Voice Customization and Design"
          }
        ]
      },
      {
        "type": "p",
        "children": [
          {
            "type": "text",
            "text": "Leverage the "
          },
          {
            "type": "text",
            "text": "voice_id",
            "code": true
          },
          {
            "type": "text",
            "text": " parameter to apply pre-defined or custom voice designs. Custom voices require uploading reference audio via the "
          },
          {
            "type": "text",
            "text": "/v1/voices/create",
            "code": true
          },
          {
            "type": "text",
            "text": " endpoint. Store voice IDs in a database for quick retrieval. Test synthesis with short text samples to verify voice consistency before full deployment."
          }
        ]
      },
