      {
        "type": "p",
        "children": [
          {
            "type": "text",
            "text": "Begin by obtaining an API key from the Nanonets dashboard. Use HTTPS endpoints with Bearer token authentication. Ensure requests include proper headers and payload formats, such as multipart/form-data for file uploads, to avoid common setup errors."
          }
        ]
