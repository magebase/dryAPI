      },
      {
        "type": "p",
        "children": [
          {
            "type": "text",
            "text": "Nanonets OCR S AI API supports high-accuracy text extraction from various document types, including invoices, receipts, and forms. It handles multiple languages and outputs structured data in JSON or XML formats, enabling seamless integration with existing systems."
          }
        ]
      },
      {
