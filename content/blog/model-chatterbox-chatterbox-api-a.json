            "code": true
          },
          {
            "type": "text",
            "text": " and "
          },
          {
            "type": "text",
            "text": "Authorization: Bearer <token>",
            "code": true
          },
          {
            "type": "text",
            "text": ". For chat endpoints, use POST to "
          },
          {
            "type": "text",
            "text": "/conversations",
            "code": true
          },
          {
            "type": "text",
            "text": " with a JSON body containing "
          },
          {
            "type": "text",
            "text": "user_id",
            "code": true
          },
          {
            "type": "text",
            "text": " and "
          },
