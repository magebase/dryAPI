        "type": "h2",
        "children": [
          {
            "type": "text",
            "text": "API Integration with FastAPI"
          }
        ]
      },
      {
        "type": "p",
        "children": [
          {
            "type": "text",
            "text": "Integrate the model into a FastAPI application for robust endpoints. Load the model once at startup to minimize overhead. Sample implementation:"
          }
        ]
      },
      {
        "type": "code_block",
        "lang": "python",
        "value": "from fastapi import FastAPI\nfrom bge_m3 import BGEModel\n\napp = FastAPI()\nmodel = BGEModel(model_name=\"BAAI/bge-m3\", precision=\"fp16\")\n\n@app.post(\"/embed\")\nasync def get_embeddings(texts: list[str]):\n    embeddings = model.encode(texts)\n    return {\"embeddings\": embeddings.tolist()}",
        "children": [
          {
            "type": "code_line",
            "children": [
              {
                "text": "from fastapi import FastAPI"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "from bge_m3 import BGEModel"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": ""
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "app = FastAPI()"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "model = BGEModel(model_name=\"BAAI/bge-m3\", precision=\"fp16\")"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": ""
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "@app.post(\"/embed\")"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "async def get_embeddings(texts: list[str]):"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "    embeddings = model.encode(texts)"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "    return {\"embeddings\": embeddings.tolist()}"
              }
            ]
          }
        ]
      },
