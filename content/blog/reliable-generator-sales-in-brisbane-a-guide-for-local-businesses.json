            "type": "li",
            "children": [
              {
                "type": "lic",
                "children": [
                  {
                    "type": "text",
                    "text": "Assess the total kilowatt (kW) requirement including peak start-up loads for all essential machinery."
                  }
                ]
              }
            ]
