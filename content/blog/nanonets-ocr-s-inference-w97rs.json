      {
        "type": "p",
        "children": [
          {
            "type": "text",
            "text": "Begin by obtaining API credentials from the Nanonets dashboard. Use HTTPS for all requests and include your API key in the header. Example curl command:"
          }
        ]
      },
      {
        "type": "code_block",
        "lang": "bash",
        "value": "curl -X POST https://api.nanonets.com/v2/ocr/s \\\n  -H 'Authorization: Basic YOUR_API_KEY' \\\n  -F 'file=@document.pdf'",
        "children": [
          {
            "type": "code_line",
