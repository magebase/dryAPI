      {
        "type": "code_block",
        "lang": "python",
        "value": "from requests.adapters import HTTPAdapter\nfrom requests.packages.urllib3.util.retry import Retry\n\nsession = requests.Session()\nretries = Retry(total=3, backoff_factor=0.1)\nsession.mount('https://', HTTPAdapter(max_retries=retries))",
        "children": [
          {
            "type": "code_line",
            "children": [
              {
                "text": "from requests.adapters import HTTPAdapter"
