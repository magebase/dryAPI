          {
            "type": "text",
            "text": "To estimate costs, consider your monthly call volume and image complexity. For example, processing 50,000 invoices monthly at $1.50 per 1,000 calls would cost $75. Use this Python snippet to calculate expenses based on your usage:"
          }
        ]
      },
      {
        "type": "code_block",
        "lang": "python",
        "value": "def calculate_ocr_cost(monthly_calls, cost_per_thousand=1.50):\n    \"\"\"Calculate monthly cost for Nanonets OCR S API usage.\"\"\"\n    if monthly_calls <= 1000:\n        return 0  # Free tier\n    cost = (monthly_calls / 1000) * cost_per_thousand\n    return round(cost, 2)\n\n# Example: 50,000 calls\nmonthly_calls = 50000\nestimated_cost = calculate_ocr_cost(monthly_calls)\nprint(f\"Estimated monthly cost: ${estimated_cost}\")",
        "children": [
          {
            "type": "code_line",
            "children": [
              {
                "text": "def calculate_ocr_cost(monthly_calls, cost_per_thousand=1.50):"
