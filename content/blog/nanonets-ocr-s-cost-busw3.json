            "type": "code_line",
            "children": [
              {
                "text": "        return 0  # Free tier"
              }
            ]
          },
          {
            "type": "code_line",
            "children": [
              {
                "text": "    cost = (monthly_calls / 1000) * cost_per_thousand"
              }
            ]
          },
          {
            "type": "code_line",
