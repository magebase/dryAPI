      {
        "type": "code_block",
        "lang": "python",
        "value": "import redis\nimport hashlib\n\nr = redis.Redis(host='localhost', port=6379, db=0)\n\ndef cached_ben2_call(data):\n    data_hash = hashlib.md5(json.dumps(data).encode()).hexdigest()\n    cache_key = f\"ben2:{data_hash}\"\n    cached = r.get(cache_key)\n    if cached:\n        return json.loads(cached)\n    result = process_with_ben2(data)\n    r.setex(cache_key, 3600, json.dumps(result))  # Cache for 1 hour\n    return result",
