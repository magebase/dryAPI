        "value": "import requests\nimport json\n\ndef process_with_ben2(data):\n    url = f\"{os.environ['BEN2_ENDPOINT']}/process\"\n    headers = {'Authorization': f\"Bearer {os.environ['BEN2_API_KEY']}\"}\n    payload = {'data': data}\n    response = requests.post(url, json=payload, headers=headers, timeout=30)\n    response.raise_for_status()\n    return response.json()",
