      {
        "type": "p",
        "children": [
          {
            "type": "text",
            "text": "For synthesis requests, the "
          },
          {
            "type": "text",
            "text": "text",
            "code": true
          },
          {
            "type": "text",
            "text": " parameter supports up to 5000 characters. Responses include a "
          },
          {
            "type": "text",
            "text": "audio_url",
            "code": true
          },
          {
            "type": "text",
            "text": " for temporary download or a base64-encoded "
          },
          {
            "type": "text",
            "text": "audio_data",
            "code": true
          },
          {
            "type": "text",
            "text": " field based on the "
          },
