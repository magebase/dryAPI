# Copy to .env.test for local Cloudflare API Playwright E2E runs.
# This file configures both Playwright and the wrangler dev worker started by tests.

CF_E2E_WORKER_ENV=test
CF_E2E_API_HOST=127.0.0.1
CF_E2E_API_PORT=8877
CF_E2E_BASE_URL=http://127.0.0.1:8877

CF_E2E_RUNPOD_PORT=8878
CF_E2E_RUNPOD_BASE_URL=http://127.0.0.1:8878/v2

CF_E2E_API_KEY=test-api-key
CF_E2E_INTERNAL_API_KEY=test-internal-api-key
CF_E2E_RUNPOD_API_KEY=test-runpod-api-key
CF_E2E_WEBHOOK_SIGNING_SECRET=test-webhook-signing-secret

CF_E2E_ENDPOINT_CHAT=e2e-chat-endpoint
CF_E2E_ENDPOINT_IMAGES=e2e-images-endpoint
CF_E2E_ENDPOINT_EMBEDDINGS=e2e-embeddings-endpoint
CF_E2E_ENDPOINT_TRANSCRIBE=e2e-transcribe-endpoint

CF_E2E_WS_INLINE_MAX_BYTES=65536

# Diagnostics log level (log|info|warn|error|silent)
# Keep default at warn so console.log/info debug noise is off by default.
LOG_LEVEL=warn
NEXT_PUBLIC_LOG_LEVEL=warn
