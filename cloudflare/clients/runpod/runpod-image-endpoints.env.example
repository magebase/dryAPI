# RunPod API settings
RUNPOD_API_KEY=
RUNPOD_GRAPHQL_URL=https://api.runpod.io/graphql

# Endpoint template IDs by worker class
RUNPOD_TEMPLATE_ID_TEXT_MUSIC=
RUNPOD_TEMPLATE_ID_EMBEDDINGS_TEXT=
RUNPOD_TEMPLATE_ID_BACKGROUND_REMOVAL=
RUNPOD_TEMPLATE_ID_DIFFUSERS_IMAGE=
RUNPOD_TEMPLATE_ID_LTX_VIDEO=
RUNPOD_TEMPLATE_ID_VLM_OCR=
RUNPOD_TEMPLATE_ID_TTS_CUSTOMVOICE=
RUNPOD_TEMPLATE_ID_IMAGE_UPSCALE=
RUNPOD_TEMPLATE_ID_AUDIO_TRANSCRIBE=

# Optional network volume id if your template needs one
RUNPOD_NETWORK_VOLUME_ID=

# Optional defaults
RUNPOD_DEFAULT_IDLE_TIMEOUT_SECONDS=60
