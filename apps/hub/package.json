{
  "name": "apiscore-hub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3001 --turbopack",
    "dev:webpack": "next dev --port 3001 --webpack",
    "build": "next build --webpack",
    "start": "next start --port 3001",
    "lint": "eslint",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate:local": "wrangler d1 migrations apply \"${CF_D1_DATABASE_NAME_HUB:-apiscore-hub-db-local}\" --local --config wrangler.local.jsonc",
    "db:migrate:remote": "wrangler d1 migrations apply \"${CF_D1_DATABASE_NAME_HUB:-apiscore-hub-db}\" --remote --config wrangler.jsonc",
    "cf:build": "rm -rf .open-next && opennextjs-cloudflare build && pnpm sitemap",
    "cf:preview": "opennextjs-cloudflare preview",
    "cf:deploy:only": "opennextjs-cloudflare deploy",
    "cf:deploy": "pnpm cf:build && pnpm cf:deploy:only",
    "sitemap": "next-sitemap"
  },
  "dependencies": {
    "@better-auth/api-key": "^1.5.5",
    "@hookform/resolvers": "^5.2.2",
    "@opennextjs/cloudflare": "^1.17.1",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@takumi-rs/image-response": "^0.73.1",
    "@takumi-rs/wasm": "^0.73.1",
    "better-auth": "^1.5.5",
    "better-auth-cloudflare": "^0.2.9",
    "better-auth-harmony": "^1.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.8",
    "lodash": "^4.17.23",
    "lucide-react": "^0.575.0",
    "ms": "^2.1.3",
    "nanoid": "^5.1.6",
    "next": "16.1.6",
    "next-seo": "^7.2.0",
    "next-sitemap": "^4.2.3",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.13.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash": "^4.17.24",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.0",
    "wrangler": "^4.76.0"
  },
  "engines": {
    "node": "25.x"
  }
}
