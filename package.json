{
  "name": "dryapi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prebuild": "tsx scripts/verify-takumi-og.ts && tsx scripts/generate-hono-openapi-pages.ts && tsx scripts/generate-llm-text.ts",
    "prepare": "lefthook install",
    "hooks:install": "lefthook install",
    "admin:repair": "tsx scripts/repair-admin-index.ts",
    "sync:github-en": "bash ./scripts/sync-github-en.sh --env-file .env",
    "predev": "npm run -s admin:repair && pnpm db:migrate && pnpm docs:openapi:hono",
    "dev": "[ -f .env.local ] && pnpm dotenv -e .env.local -- bash ./scripts/dev-with-api.sh || bash ./scripts/dev-with-api.sh",
    "dev:auto": "bash ./scripts/dev-autorestart.sh",
    "predev:next": "npm run -s admin:repair && pnpm db:migrate && pnpm docs:openapi:hono",
    "dev:next": "[ -f .env.local ] && pnpm dotenv -e .env.local -- next dev --turbopack || next dev --turbopack",
    "dev:next:webpack": "next dev --webpack",
    "dev:tina": "tinacms dev -c \"next dev --turbopack\"",
    "dev:tina:webpack": "tinacms dev -c \"next dev --webpack\"",
    "dev:api": "cd cloudflare/api && ../../node_modules/.bin/wrangler dev --config wrangler.toml --ip 127.0.0.1 --port 8787 --local",
    "build": "next build --webpack",
    "tina:build": "tinacms build --local --skip-cloud-checks",
    "build:tina": "tinacms build --local --skip-cloud-checks && pnpm build",
    "prestart": "npm run -s admin:repair",
    "start": "next start",
    "lint": "eslint",
    "test": "[ -f .env.local ] && pnpm dotenv -e .env.local -- vitest run || vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:cf:integration": "vitest run --config cloudflare/api/vitest.integration.config.mts",
    "test:cf:integration:coverage": "vitest run --config cloudflare/api/vitest.integration.config.mts --coverage",
    "test:cf:e2e": "vitest run --config cloudflare/api/vitest.e2e.config.mts",
    "test:cf:e2e:headed": "vitest run --config cloudflare/api/vitest.e2e.config.mts --reporter=verbose",
    "test:cf:e2e:debug": "vitest --config cloudflare/api/vitest.e2e.config.mts --reporter=verbose",
    "capture:landing:screenshots": "tsx scripts/playwright/capture-landing-slot-screenshots.ts",
    "capture:landing:videos": "tsx scripts/playwright/capture-landing-slot-cinematic-videos.ts",
    "capture:landing:demo": "tsx scripts/playwright/capture-landing-full-demo.ts",
    "capture:landing:feature-actions": "tsx scripts/playwright/capture-feature-action-videos.ts",
    "capture:landing:all": "pnpm capture:landing:screenshots && pnpm capture:landing:videos && pnpm capture:landing:demo",
    "capture:landing:all:extended": "pnpm capture:landing:all && pnpm capture:landing:feature-actions",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "tsx scripts/apply-migrations.ts",
    "cf:build": "pnpm dotenv -e .env -- bash -c 'rm -rf .open-next && tinacms build --local --skip-cloud-checks && opennextjs-cloudflare build && pnpm sitemap'",
    "cf:preview": "opennextjs-cloudflare preview",
    "cf:deploy:only": "tsx scripts/cf-deploy-multi-worker.ts",
    "cf:deploy": "npm run -s cf:build && npm run -s cf:deploy:only",
    "cf:secrets:sync:all": "bash ./scripts/sync-worker-secrets-from-env.sh --env-file .env",
    "cf:chatbot:ai-search:sync": "bash ./scripts/cf-chatbot-ai-search-sync.sh --env-file .env --config wrangler.jsonc",
    "cf:chatbot:ai-search:ensure": "tsx scripts/cf-chatbot-ai-search-ensure.ts",
    "cf:notifications:ensure": "tsx scripts/cf-notifications-ensure.ts",
    "cf:chatbot:ai-search:check": "bash ./scripts/cf-chatbot-ai-search-sync.sh --env-file .env --config wrangler.jsonc --dry-run",
    "cf:chatbot:ai-search:recrawl": "tsx scripts/cf-chatbot-ai-search-recrawl.ts",
    "cf:client:init": "bash ./scripts/cf-client-init.sh",
    "cf:access:admin:provision": "tsx ./scripts/cf-zero-trust-admin-provision.ts",
    "cf:access:tina:disable": "tsx ./scripts/cf-zero-trust-tina-disable.ts",
    "cf:calcom:install": "pnpm --dir cloudflare/container install",
    "cf:calcom:dev": "pnpm --dir cloudflare/container dev",
    "cf:calcom:deploy": "pnpm --dir cloudflare/container deploy",
    "cf:workflows:install": "pnpm --dir cloudflare/workflows install",
    "cf:workflows:dev": "pnpm --dir cloudflare/workflows dev",
    "cf:workflows:deploy": "pnpm --dir cloudflare/workflows deploy",
    "sitemap": "next-sitemap",
    "postbuild": "pnpm sitemap",
    "stripe:portal:init-local": "tsx scripts/stripe-portal-env-init.ts --env-file .env",
    "stripe:portal:ensure": "tsx scripts/stripe-portal-ensure.ts",
    "stripe:portal:sync": "tsx scripts/stripe-pulumi-sync.ts",
    "stripe:meters:ensure": "tsx scripts/stripe-meters-ensure.ts",
    "stripe:saas:plans:ensure": "tsx scripts/stripe-saas-plans-ensure.ts",
    "brevo:marketing-list:ensure": "tsx scripts/brevo-marketing-list-ensure.ts",
    "docs:openapi:hono": "tsx scripts/generate-hono-openapi-pages.ts",
    "docs:sync:deapi": "echo 'Script disabled. Documentation should be manually edited to preserve dryAPI branding and model accuracy.'",
    "og:verify": "tsx scripts/verify-takumi-og.ts",
    "pricing:sync:runpod": "tsx scripts/sync-runpod-pricing.ts",
    "pricing:sync:runpod:daily": "tsx scripts/sync-runpod-pricing-daily.ts",
    "pricing:sync:deapi": "tsx scripts/sync-deapi-pricing.ts",
    "pricing:sync:deapi:daily": "tsx scripts/sync-deapi-pricing-daily.ts",
    "seo:models:generate": "tsx scripts/generate-model-keyword-pages.ts",
    "brand:scaffold": "tsx scripts/scaffold-brand-instance.ts",
    "models:check:detail-routes": "tsx scripts/check-model-detail-routes.ts",
    "footer:sort:page-analytics": "tsx scripts/sort-footer-blog-links-by-page-analytics.ts",
    "runpod:endpoints:image:optimize-gpu-revenue": "tsx scripts/optimize-runpod-gpu-revenue.ts --write",
    "runpod:endpoints:image:build": "tsx scripts/build-runpod-image-endpoints.ts",
    "runpod:endpoints:image:pulumi:install": "pnpm --dir cloudflare/clients/runpod/pulumi install",
    "runpod:endpoints:image:pulumi:preview": "bash ./scripts/runpod-endpoints-pulumi.sh preview",
    "runpod:endpoints:image:pulumi:up": "bash ./scripts/runpod-endpoints-pulumi.sh up",
    "runpod:endpoints:image:pulumi:deploy": "bash ./scripts/runpod-endpoints-pulumi.sh deploy",
    "runpod:endpoints:image:pulumi:destroy": "bash ./scripts/runpod-endpoints-pulumi.sh destroy",
    "runpod:endpoints:image:redeploy": "bash ./scripts/runpod-endpoints-pulumi-redeploy.sh"
  },
