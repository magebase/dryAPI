{
  "name": "genfix",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prebuild": "node scripts/generate-hono-openapi-pages.mjs && node scripts/generate-llm-text.mjs",
    "prepare": "lefthook install",
    "hooks:install": "lefthook install",
    "admin:repair": "node scripts/repair-admin-index.mjs",
    "sync:github-en": "bash ./scripts/sync-github-en.sh --env-file .env",
    "predev": "npm run -s admin:repair && pnpm db:migrate:local && pnpm docs:openapi:hono",
    "dev": "bash ./scripts/dev-with-api.sh",
    "dev:auto": "bash ./scripts/dev-autorestart.sh",
    "predev:next": "npm run -s admin:repair && pnpm db:migrate:local && pnpm docs:openapi:hono",
    "dev:next": "next dev --webpack",
    "dev:tina": "tinacms dev -c \"next dev --webpack\"",
    "dev:api": "pnpm exec wrangler dev --config cloudflare/api/wrangler.toml --ip 127.0.0.1 --port 8787 --local",
    "build": "next build --webpack",
    "tina:build": "tinacms build --local --skip-cloud-checks",
    "build:tina": "tinacms build --local --skip-cloud-checks && pnpm build",
    "prestart": "npm run -s admin:repair",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:cf:integration": "vitest run --config cloudflare/api/vitest.integration.config.mts",
    "test:cf:integration:coverage": "vitest run --config cloudflare/api/vitest.integration.config.mts --coverage",
    "test:cf:e2e": "playwright test --config cloudflare/api/playwright.config.mjs",
    "test:cf:e2e:headed": "playwright test --config cloudflare/api/playwright.config.mjs --headed",
    "test:cf:e2e:debug": "PWDEBUG=1 playwright test --config cloudflare/api/playwright.config.mjs --workers=1",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply \"${CF_D1_DATABASE_NAME:-genfix-db-local}\" --local --config wrangler.local.jsonc",
    "db:migrate:remote": "wrangler d1 migrations apply \"${CF_D1_DATABASE_NAME:-genfix-db}\" --remote --config wrangler.jsonc",
    "cf:build": "rm -rf .open-next .next && tinacms build --local --skip-cloud-checks && opennextjs-cloudflare build && pnpm sitemap",
    "cf:preview": "opennextjs-cloudflare preview",
    "cf:deploy": "npm run -s cf:build && opennextjs-cloudflare deploy",
    "cf:secrets:sync:all": "bash ./scripts/sync-worker-secrets-from-env.sh --env-file .env",
    "cf:chatbot:ai-search:sync": "bash ./scripts/cf-chatbot-ai-search-sync.sh --env-file .env --config wrangler.jsonc",
    "cf:chatbot:ai-search:check": "bash ./scripts/cf-chatbot-ai-search-sync.sh --env-file .env --config wrangler.jsonc --dry-run",
    "cf:client:init": "bash ./scripts/cf-client-init.sh",
    "cf:access:admin:provision": "node ./scripts/cf-zero-trust-admin-provision.mjs",
    "cf:access:tina:disable": "node ./scripts/cf-zero-trust-tina-disable.mjs",
    "cf:calcom:install": "pnpm --dir cloudflare/container install",
    "cf:calcom:dev": "pnpm --dir cloudflare/container dev",
    "cf:calcom:deploy": "pnpm --dir cloudflare/container deploy",
    "cf:workflows:install": "pnpm --dir cloudflare/workflows install",
    "cf:workflows:dev": "pnpm --dir cloudflare/workflows dev",
    "cf:workflows:deploy": "pnpm --dir cloudflare/workflows deploy",
    "sitemap": "next-sitemap",
    "postbuild": "pnpm sitemap",
    "stripe:portal:init-local": "node scripts/stripe-portal-env-init.mjs --env-file .env",
    "stripe:portal:ensure": "node scripts/stripe-portal-ensure.mjs",
    "stripe:meters:ensure": "node scripts/stripe-meters-ensure.mjs",
    "brevo:marketing-list:ensure": "node scripts/brevo-marketing-list-ensure.mjs",
    "docs:openapi:hono": "node scripts/generate-hono-openapi-pages.mjs",
    "docs:sync:deapi": "node scripts/sync-deapi-docs.mjs && node scripts/generate-hono-openapi-pages.mjs",
    "pricing:sync:deapi": "node scripts/sync-deapi-pricing.mjs",
    "pricing:sync:deapi:daily": "node scripts/sync-deapi-pricing-daily.mjs",
    "models:check:detail-routes": "node scripts/check-model-detail-routes.mjs",
    "runpod:endpoints:image:optimize-gpu-revenue": "node scripts/optimize-runpod-gpu-revenue.mjs --write",
    "runpod:endpoints:image:build": "node scripts/build-runpod-image-endpoints.mjs",
    "runpod:endpoints:image:pulumi:install": "pnpm --dir cloudflare/clients/runpod/pulumi install",
    "runpod:endpoints:image:pulumi:preview": "bash ./scripts/runpod-endpoints-pulumi.sh preview",
    "runpod:endpoints:image:pulumi:up": "bash ./scripts/runpod-endpoints-pulumi.sh up",
    "runpod:endpoints:image:pulumi:deploy": "bash ./scripts/runpod-endpoints-pulumi.sh deploy",
    "runpod:endpoints:image:pulumi:destroy": "bash ./scripts/runpod-endpoints-pulumi.sh destroy",
    "runpod:endpoints:image:redeploy": "bash ./scripts/runpod-endpoints-pulumi-redeploy.sh"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1005.0",
    "@aws-sdk/s3-request-presigner": "^3.1006.0",
    "@base-ui/react": "^1.3.0",
    "@hono/standard-validator": "^0.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@microsoft/clarity": "^1.0.2",
    "@opennextjs/cloudflare": "^1.17.1",
    "@react-email/components": "^1.0.8",
    "@react-email/render": "^2.0.4",
    "@serwist/next": "^9.5.6",
    "@standard-community/standard-json": "^0.3.5",
    "@standard-community/standard-openapi": "^0.2.9",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@tanstack/react-virtual": "^3.13.21",
    "@tinacms/cli": "^2.1.9",
    "@tinacms/datalayer": "2.0.12",
    "@tinacms/graphql": "2.2.0",
    "@tinacms/mdx": "2.0.7",
    "@tinacms/schema-tools": "2.7.0",
    "@types/json-schema": "^7.0.15",
    "@unkey/api": "^2.3.1",
    "@upstash/redis": "^1.36.3",
    "abstract-level": "^1.0.4",
    "aos": "^2.3.4",
    "better-auth": "^1.5.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cookieconsent": "^3.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "embla-carousel-react": "^8.6.0",
    "feed": "^5.2.0",
    "fumadocs-core": "16.6.17",
    "fumadocs-mdx": "14.2.10",
    "fumadocs-openapi": "10.3.18",
    "fumadocs-ui": "16.6.17",
    "gradient-gl": "^1.5.0",
    "hono": "^4.12.7",
    "hono-openapi": "^1.3.0",
    "input-otp": "^1.4.2",
    "jose": "^6.2.1",
    "lenis": "^1.3.17",
    "lucide-react": "^0.575.0",
    "millify": "^6.1.0",
    "module-error": "^1.0.2",
    "ms": "^2.1.3",
    "nanoid": "^5.1.6",
    "next": "16.1.6",
    "next-safe-action": "^8.1.8",
    "next-seo": "^7.2.0",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "openapi-types": "^12.1.3",
    "ra-data-simple-rest": "^5.14.4",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-admin": "^5.14.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.7.3",
    "recharts": "2.15.4",
    "remark-gfm": "^4.0.1",
    "resend": "^6.9.3",
    "server-only": "^0.0.1",
    "shadcn": "^3.8.5",
    "sonner": "^2.0.7",
    "stripe": "^20.4.1",
    "stripe-event-types": "^3.1.0",
    "tailwind-merge": "^3.5.0",
    "tinacms": "^3.6.1",
    "tinacms-gitprovider-github": "4.0.12",
    "tw-animate-css": "^1.4.0",
    "typebox": "^1.1.6",
    "upstash-redis-level": "1.1.1",
    "vaul": "^1.1.2",
    "zod": "^4.3.6",
    "zod-form-data": "^3.0.1"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.13.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/aos": "^3.0.7",
    "@types/mdx": "^2.0.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/testing-library__jest-dom": "^5.14.9",
    "@vitest/coverage-istanbul": "4.0.18",
    "@vitest/coverage-v8": "^4.1.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.1.0",
    "lefthook": "^1.12.4",
    "next-sitemap": "^4.2.3",
    "playwright": "^1.54.2",
    "serwist": "^9.5.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.0",
    "wrangler": "^4.73.0"
  },
  "pnpm": {
    "patchedDependencies": {
      "js-sha1@0.6.0": "patches/js-sha1@0.6.0.patch",
      "tinacms@3.6.1": "patches/tinacms@3.6.1.patch"
    }
  },
  "engines": {
    "node": "25.x"
  }
}
